{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ingram Micro CRM",
  "version": "0.12.2",
  "identifier": "com.ingramcrm.app",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm sync-version && pnpm dev",
    "beforeBuildCommand": "pnpm sync-version && pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Ingram Micro CRM",
        "width": 1300,
        "height": 700,
        "minWidth": 1400,
        "minHeight": 650,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: asset: https://login.microsoftonline.com https://login.microsoft.com https://graph.microsoft.com; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https: blob:; connect-src 'self' https://login.microsoftonline.com https://login.microsoft.com https://graph.microsoft.com https://*.api.crm4.dynamics.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "createUpdaterArtifacts": "v1Compatible",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "nsis/hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/DylanHias/IM-CRM/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU3MEEyRDIwMEQwRTc5QUQKUldTdGVRNE5JQzBLNTVTMy9PVGJYc2RReUN4dzB3c2x1a2prOExnRFFkV1QvRGtCa2ZqaTFxa1YK"
    }
  }
}
